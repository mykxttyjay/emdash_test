---
import Layout from "../layouts/Layout.astro";
import Header from "../components/sections/Header.astro";
import Hero2 from "../components/sections/Hero2.astro";
import AboutSection from "../components/sections/About.astro";
import Services from "../components/sections/Services.astro";
import Stats from "../components/sections/Stats.astro";
import FAQ from "../components/sections/FAQ.astro";
import Location from "../components/sections/Location.astro";
import Footer from "../components/sections/Footer.astro";
import FloatingOffer from "../components/sections/FloatingOffer.astro";
import FloatingSideButtons from "../components/sections/FloatingSideButtons.astro";
import OfferModal from "../components/sections/OfferModal.astro";
---

<Layout 
  title="About Electrixa" 
>
    <Header /> 
    <Hero2 title="About Us" />
    <AboutSection />
    <Services />
    <Stats />
    <FAQ />
    <Location />
    <Footer />
    <FloatingOffer />
    <FloatingSideButtons showOnScroll={true} triggerSection="about" />
    <OfferModal />
</Layout>
