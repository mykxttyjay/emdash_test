---
import Layout from "../layouts/Layout.astro";
import Header from "../components/sections/Header.astro";
import Hero2 from "../components/sections/Hero2.astro";
import LocationSection from "../components/sections/Location.astro";
import FAQ from "../components/sections/FAQ.astro";
import CallToAction from "../components/sections/CallToAction.astro";
import Footer from "../components/sections/Footer.astro";
import FloatingOffer from "../components/sections/FloatingOffer.astro";
import FloatingSideButtons from "../components/sections/FloatingSideButtons.astro";
import OfferModal from "../components/sections/OfferModal.astro";
---

<Layout 
  title="Service Areas" 
>
    <Header />
    
    <Hero2 
        title="Service Areas" 
        backgroundImage="https://images.unsplash.com/photo-1517420704952-d9f39e95b43e?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
    />

    <LocationSection />
    <FAQ />
    <CallToAction />
    <Footer />
    <FloatingOffer />
    <FloatingSideButtons showOnScroll={true} triggerSection="faq" />
    <OfferModal />
</Layout>
