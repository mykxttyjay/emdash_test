---
import Layout from "../layouts/Layout.astro";
import Header from "../components/sections/Header.astro";
import Hero2 from "../components/sections/Hero2.astro";
import WhyChooseUs from '../components/sections/WhyChooseUs.astro';
import ServicesSection from "../components/sections/Services.astro";
import Location from "../components/sections/Location.astro";
import CallToAction from "../components/sections/CallToAction.astro";
import Footer from "../components/sections/Footer.astro";
import FloatingOffer from "../components/sections/FloatingOffer.astro";
import FloatingSideButtons from "../components/sections/FloatingSideButtons.astro";
import OfferModal from "../components/sections/OfferModal.astro";
---

<Layout 
  title="Electrical Services" 
>
    <Header />
    
    <Hero2 
        title="Our Services" 
        backgroundImage="https://images.unsplash.com/photo-1724047394877-709406ca5f2e?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
    />

    <ServicesSection />
    <WhyChooseUs />
    <CallToAction />
    <Location />
    <Footer />
    <FloatingOffer />
    <FloatingSideButtons showOnScroll={true} triggerSection="why-choose-us" />
    <OfferModal />
</Layout>
