import Header from "../components/sections/Header.astro";
import Hero2 from "../components/sections/Hero2.astro";
import FinancingSection from "../components/sections/Financing.astro";
import WorkingProcess from "../components/sections/WorkingProcess.astro";
import FAQ from "../components/sections/FAQ.astro";
import CallToAction from "../components/sections/CallToAction.astro";
import Footer from "../components/sections/Footer.astro";
import FloatingOffer from "../components/sections/FloatingOffer.astro";
import OfferModal from "../components/sections/OfferModal.astro";
---

