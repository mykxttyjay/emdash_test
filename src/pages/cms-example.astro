---
import Layout from '../layouts/Layout.astro';
import { getServices, getTestimonials, getPortfolio } from '../lib/cms';

// Fetch data from CMS
const services = await getServices();
const testimonials = await getTestimonials();
const portfolio = await getPortfolio();
---

<Layout title="CMS Example - Dynamic Content">
  <div class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-8">CMS Content Example</h1>
    
    <div class="mb-8 p-6 bg-blue-50 rounded-lg">
      <p class="text-lg">
        This page demonstrates how to fetch and display content from EmDash CMS.
        Access the admin panel at <a href="/_emdash/admin" class="text-blue-600 underline font-semibold">/_emdash/admin</a>
      </p>
    </div>

    <!-- Services -->
    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-6">Services from CMS</h2>
      {services.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {services.map((service: any) => (
            <div class="border rounded-lg p-6 shadow-md">
              <h3 class="text-xl font-bold mb-2">{service.data.title || service.title}</h3>
              <p class="text-gray-600 mb-4">{service.data.description || service.description}</p>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-gray-500">No services found. Add some in the CMS at <a href="/_emdash/admin" class="text-blue-600 underline">/_emdash/admin</a></p>
      )}
    </section>

    <!-- Testimonials -->
    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-6">Testimonials from CMS</h2>
      {testimonials.length > 0 ? (
        <div class="grid md:grid-cols-2 gap-6">
          {testimonials.map((testimonial: any) => (
            <div class="border rounded-lg p-6 shadow-md">
              <div class="flex items-center mb-2">
                <span class="text-yellow-500">
                  {'★'.repeat(testimonial.data?.rating || testimonial.rating || 5)}{'☆'.repeat(5 - (testimonial.data?.rating || testimonial.rating || 5))}
                </span>
              </div>
              <p class="text-gray-700 mb-4 italic">"{testimonial.data?.text || testimonial.text}"</p>
              <p class="font-semibold">{testimonial.data?.name || testimonial.name}</p>
              {(testimonial.data?.location || testimonial.location) && (
                <p class="text-sm text-gray-500">{testimonial.data?.location || testimonial.location}</p>
              )}
            </div>
          ))}
        </div>
      ) : (
        <p class="text-gray-500">No testimonials found. Add some in the CMS at <a href="/_emdash/admin" class="text-blue-600 underline">/_emdash/admin</a></p>
      )}
    </section>

    <!-- Portfolio -->
    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-6">Portfolio from CMS</h2>
      {portfolio.length > 0 ? (
        <div class="grid md:grid-cols-3 gap-6">
          {portfolio.map((project: any) => (
            <div class="border rounded-lg overflow-hidden shadow-md">
              {(project.data?.image || project.image) && (
                <img src={project.data?.image || project.image} alt={project.data?.title || project.title} class="w-full h-48 object-cover" />
              )}
              <div class="p-4">
                <h3 class="text-xl font-bold mb-2">{project.data?.title || project.title}</h3>
                {(project.data?.category || project.category) && (
                  <span class="inline-block bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded mb-2">
                    {project.data?.category || project.category}
                  </span>
                )}
                <p class="text-gray-600">{project.data?.description || project.description}</p>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-gray-500">No portfolio items found. Add some in the CMS at <a href="/_emdash/admin" class="text-blue-600 underline">/_emdash/admin</a></p>
      )}
    </section>

    <!-- Admin Link -->
    <div class="text-center mt-12 p-6 bg-blue-50 rounded-lg">
      <h3 class="text-xl font-bold mb-2">Manage Your Content</h3>
      <p class="mb-4">Access the CMS admin panel to add, edit, or remove content.</p>
      <a href="/_emdash/admin" class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition">
        Go to Admin Panel
      </a>
    </div>
  </div>
</Layout>
